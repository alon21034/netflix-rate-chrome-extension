{
  "manifest_version": 3,
  "name": "Netflix Ratings Overlay",
  "description": "Chrome extension scaffold for adding ratings overlays on Netflix cards.",
  "version": "0.1.0",
  "permissions": ["storage"],
  "host_permissions": ["https://www.netflix.com/*", "https://www.omdbapi.com/*"],
  "action": {
    "default_title": "Netflix Ratings Overlay",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["https://www.netflix.com/*"],
      "js": ["src/content.ts"],
      "run_at": "document_idle"
    }
  ]
}
